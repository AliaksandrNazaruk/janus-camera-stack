      "description": "SLO: ≤ 1%",
      "type": "timeseries",
      "targets": [
        { "expr": "camstack_client_packet_loss_ratio", "legendFormat": "{{camera}}" }
      ]
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 14 },
      "id": 13,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "title": "Client Frames Decoded (total)",
      "type": "timeseries",
      "targets": [
        { "expr": "camstack_client_frames_decoded_total", "legendFormat": "{{camera}}" }
      ]
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 30 },
              { "color": "red", "value": 60 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 14 },
      "id": 14,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Client Last Report Age",
      "description": "Seconds since last stats_report telemetry",
      "type": "stat",
      "targets": [
        { "expr": "camstack_client_last_report_age_seconds", "legendFormat": "{{camera}}" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "id": 102,
      "title": "FDIR & Recovery",
      "type": "row"
    },
