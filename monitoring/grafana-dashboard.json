      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "title": "Mode Transitions",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(camstack_mode_transitions_total[5m])",
          "legendFormat": "{{from_mode}} → {{to_mode}}"
