        {
          "expr": "rate(camstack_watchdog_healthy_total[5m])",
          "legendFormat": "healthy/s"
        }
      ]
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": { "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 23 },
