      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "title": "ICE Connections (rate)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(camstack_ice_connects_total[5m])",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 39 },
      "id": 103,
      "title": "Availability SLO",
      "type": "row"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.99 },
              { "color": "green", "value": 0.995 }
            ]
          },
          "min": 0.95,
          "max": 1.0
        }
      },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 40 },
      "id": 30,
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Stream Availability (1h window)",
      "description": "SLO: ≥ 99%",
      "type": "stat",
      "targets": [
        {
          "expr": "avg_over_time(camstack_stream_active[1h])",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0.95,
          "max": 1.0
        }
      },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 40 },
      "id": 31,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "title": "Stream Availability (24h trend)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "avg_over_time(camstack_stream_active[1h])",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.95 },
              { "color": "green", "value": 0.99 }
            ]
          },
          "min": 0.9,
          "max": 1.0
        }
      },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 40 },
      "id": 32,
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Watchdog Health Ratio (1h)",
      "description": "healthy_checks / total_checks",
      "type": "stat",
      "targets": [
        {
          "expr": "rate(camstack_watchdog_healthy_total[1h]) / rate(camstack_watchdog_checks_total[1h])",
          "legendFormat": "{{instance}}"
        }
      ]
