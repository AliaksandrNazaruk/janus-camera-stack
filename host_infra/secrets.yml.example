---
# host_infra/secrets.yml.example
#
# Copy to secrets.yml and fill in real values:
#   cp secrets.yml.example secrets.yml
#   chmod 600 secrets.yml
#   $EDITOR secrets.yml
#
# Generate strong secrets:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
#
# secrets.yml is .gitignored — never committed.
# Loaded via site.yml `vars_files`.
#
# Eventual migration target: ansible-vault encrypt-string на каждое значение,
# хранить inline в group_vars и расшифровывать через --ask-vault-pass.
# Сейчас простой external file для скорости.

# Janus streaming plugin admin_key — для admin REST API (mountpoints CRUD).
# Ранее был placeholder "stream-admin-123" (security debt).
janus_streaming_admin_key: "<SET-ME>"

# Per-camera mountpoint admin secret (для destroy mountpoint через admin API).
# Ранее был placeholder "changeme". Per-camera dict — нужно entry для каждой
# камеры из cameras: dict в group_vars/all.yml.
cameras_secrets:
  cam-rgb:   "<SET-ME>"
  cam-depth: "<SET-ME>"   # Sprint X3 — depth mountpoint (Janus 1306)
  cam-ir1:   "<SET-ME>"   # Sprint X3 — IR left  mountpoint (1307)
  cam-ir2:   "<SET-ME>"   # Sprint X3 — IR right mountpoint (1308)

# Janus textroom plugin admin secret — для room destroy/admin operations.
# Ранее реюзил sudo password (security antipattern).
janus_textroom_secret: "<SET-ME>"

# TURN shared secret (HMAC-SHA1 для use-auth-secret protocol).
# Read by janus-turn-rotator из /etc/robot/camera-secrets.env (host-managed, not via Ansible).
# Не дублируем здесь — single source of truth: /etc/robot/camera-secrets.env.
