{# rs-depth.tuning.env — operator-tunable.  RealSense depth → colorized RGB8 → H264 #}
# === TUNING — operator-editable ===
# Restart: sudo systemctl restart rs-stream@depth.service

FIFO_PATH="/run/realsense/depth.fifo"
PIX_FMT="rgb24"
WIDTH="{{ rs_depth_width | default(640) }}"
HEIGHT="{{ rs_depth_height | default(480) }}"
FPS="{{ rs_depth_fps | default(15) }}"

BITRATE_KBPS="{{ rs_depth_bitrate_kbps | default(1000) }}"
GOP="{{ rs_depth_gop | default(15) }}"
PRESET="{{ rs_depth_preset | default('veryfast') }}"
TUNE="{{ rs_depth_tune | default('zerolatency') }}"

# Image rotation: 0|90|180|270. Mux output orientation; can adjust at L4 UI.
ROTATION="{{ rs_depth_rotation | default(0) }}"
