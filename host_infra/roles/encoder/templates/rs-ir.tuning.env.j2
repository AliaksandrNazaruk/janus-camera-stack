{# rs-ir{1,2}.tuning.env — operator-tunable.  IR Y8 grayscale → H264 #}
# === TUNING — operator-editable ===
# Restart: sudo systemctl restart rs-stream@ir{{ ir_index }}.service

FIFO_PATH="/run/realsense/ir{{ ir_index }}.fifo"
PIX_FMT="gray"
WIDTH="{{ rs_ir_width | default(640) }}"
HEIGHT="{{ rs_ir_height | default(480) }}"
FPS="{{ rs_ir_fps | default(15) }}"

BITRATE_KBPS="{{ rs_ir_bitrate_kbps | default(800) }}"
GOP="{{ rs_ir_gop | default(15) }}"
PRESET="{{ rs_ir_preset | default('veryfast') }}"
TUNE="{{ rs_ir_tune | default('zerolatency') }}"

ROTATION="{{ rs_ir_rotation | default(0) }}"
