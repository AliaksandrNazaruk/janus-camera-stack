# Example tuning.env для RTSP IP camera adapter (Sprint B4).
#
# Deploy:
#   sudo cp rtp-rtsp-example.tuning.env /etc/robot/rtp-rtsp-<instance>.tuning.env
#   sudo $EDITOR /etc/robot/rtp-rtsp-<instance>.tuning.env
#   sudo systemctl restart rtp-rtsp@<instance>

# ── RTSP source ──────────────────────────────────────────────────
# REQUIRED. Full RTSP URL including credentials если нужны.
# Common patterns:
#   rtsp://192.168.1.100:554/stream1                      # no auth
#   rtsp://user:pass@192.168.1.100:554/cam/realmonitor    # basic auth
#   rtsp://admin:secret@10.0.0.50/profile1                # ONVIF camera
# Test from CLI: ffmpeg -i "$RTSP_URL" -t 5 -f null -
RTSP_URL=""

# ── Transport ────────────────────────────────────────────────────
# tcp — reliable, retransmissions. Default. Recommended unless camera doesn't support.
# udp — lower latency но fragile to LAN drops.
TRANSPORT="tcp"

# ── Output dimensions (optional — passthrough source if blank) ──
# Set к downscale large source streams (4K → 720p):
WIDTH=""    # blank = passthrough
HEIGHT=""   # blank = passthrough

# Output FPS (blank = passthrough source FPS)
FPS=""

# ── H264 encode ──────────────────────────────────────────────────
BITRATE_KBPS="1500"
GOP="30"
PRESET="veryfast"
TUNE="zerolatency"

# ── Display ──────────────────────────────────────────────────────
# Rotation: 0|90|180|270 — applied via transpose filter.
ROTATION="0"
