# Example tuning.env for generic V4L2 adapter (Sprint B2).
#
# Deploy:
#   sudo cp rtp-v4l2-example.tuning.env /etc/robot/rtp-v4l2-<instance>.tuning.env
#   sudo $EDITOR /etc/robot/rtp-v4l2-<instance>.tuning.env
#   sudo systemctl restart rtp-v4l2@<instance>
#
# Operator-tunable (Ansible writes initial only; runtime mutations preserved).

# ── Device ────────────────────────────────────────────────────────
# Path к V4L2 device. Use `v4l2-ctl --list-devices` к enumerate.
# For USB webcam typical /dev/video0; for capture card may be /dev/video1+.
DEVICE="/dev/video0"

# ── Capture ──────────────────────────────────────────────────────
# Leave PIX_FMT empty к auto-detect от device capabilities.
# Override if your camera reports format that confuses ffmpeg auto-detect.
# Common values: yuyv422 (USB webcam native), mjpeg (compressed input), nv12.
PIX_FMT=""

WIDTH="640"
HEIGHT="480"
FPS="30"

# ── H264 encode ──────────────────────────────────────────────────
BITRATE_KBPS="1500"
GOP="30"               # keyframe interval; usually FPS (1 keyframe per second)
PRESET="veryfast"
TUNE="zerolatency"

# ── Display ──────────────────────────────────────────────────────
# Rotation: 0|90|180|270 — applied via ffmpeg transpose filter.
ROTATION="0"

# ── Optional: snapshot pipeline ──────────────────────────────────
# Set к path if you want periodic JPEG snapshot (used by web thumbnail,
# watchdog, etc.). Empty = disabled (saves CPU).
# Example: SNAPSHOT_PATH="/run/v4l2-webcam/snapshot.jpg"
SNAPSHOT_PATH=""
SNAPSHOT_FPS="1"
