{# host_infra/roles/janus/templates/plugin-streaming.jcfg.j2
   Janus streaming plugin config — generated from group_vars/all.yml `cameras` dict.
   Single source of truth: один dict определяет port/mountpoint для encoder И janus.
   Меняешь cameras[X].rtp_port → автоматически синхронизируются оба компонента.

   Loop iterates per-camera, добавляя mountpoint block для каждой.
   Currently: только cam-rgb. Adding cam-depth → одна запись в cameras dict.
#}
general :
{
  enabled = "true";
  json = "true";
  load_all = "true";
  configs_folder = "/opt/janus/etc/janus/streams.d";
  allow_persistent = "true";
  admin_key = "{{ janus_streaming_admin_key }}";
};
{% for name, cam in cameras.items() %}
{{ cam.block_name }} : {
    type = "rtp";
    id = "{{ cam.mountpoint_id }}";
    description = "{{ cam.description }}";
    secret = "{{ cameras_secrets[name] }}";

    videobitrate = 0
    videobufferkf = true
    videosimulcast = false

    media = (
        {
            type = "video";
            mid = "v";
            label = "video";
            port = "{{ cam.rtp_port }}";
            rtcpport = "{{ cam.rtcp_port }}";
            pt = "{{ cam.payload_type }}";
            codec = "{{ cam.codec }}"
            fmtp = "{{ cam.fmtp }}";
            iface = "127.0.0.1";
        }
    );
};
{% endfor %}
