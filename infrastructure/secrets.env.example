# Infrastructure secrets — copy to secrets.env and fill in real values.
# NEVER commit secrets.env to version control.
#
# These placeholders are referenced in janus.jcfg, janus-nat.json,
# janus.plugin.streaming.jcfg, and turnserver.conf.
# A deploy script should sed-replace __PLACEHOLDER__ tokens with the
# values below before copying configs to the target nodes.

JANUS_ADMIN_SECRET=       # replaces __JANUS_ADMIN_SECRET__ in janus.jcfg
TURN_SHARED_SECRET=       # replaces __TURN_SHARED_SECRET__ in turnserver.conf
STREAM_ADMIN_KEY=         # replaces __STREAM_ADMIN_KEY__ in janus.plugin.streaming.jcfg

# TURN ephemeral credentials for Janus server-side ICE.
# Generate with: python3 -c "import time,hmac,hashlib,base64; s='<TURN_SHARED_SECRET>'; e=int(time.time())+365*86400; u=f'{e}:webrtc'; print(u); print(base64.b64encode(hmac.new(s.encode(),u.encode(),hashlib.sha1).digest()).decode())"
# These replace __TURN_EPHEMERAL_USER__ and __TURN_EPHEMERAL_PWD__ in janus.jcfg.
# Validity: 1 year. Regenerate before expiry.
TURN_EPHEMERAL_USER=      # format: <unix_expiry>:webrtc
TURN_EPHEMERAL_PWD=       # Base64(HMAC-SHA1(user, TURN_SHARED_SECRET))
