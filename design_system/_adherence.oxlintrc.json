{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/data/**",
              "components/feedback/**",
              "components/overlay/**",
              "ui_kits/operator-console/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:IBM Plex Mono|IBM Plex Sans))/i]",
        "message": "Font not provided by the design system. Available: IBM Plex Mono, IBM Plex Sans."
      },
      {
        "selector": "JSXOpeningElement[name.name='ActionButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|icon|iconRight|busy|block|key|ref|className|style|children)$/]",
        "message": "<ActionButton> doesn't accept that prop. Declared props: variant, size, icon, iconRight, busy, block."
      },
      {
        "selector": "JSXOpeningElement[name.name='AlertBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:severity|message|count|actionLabel|onAction|onDismiss|key|ref|className|style|children)$/]",
        "message": "<AlertBar> doesn't accept that prop. Declared props: severity, message, count, actionLabel, onAction, onDismiss."
      },
      {
        "selector": "JSXOpeningElement[name.name='AlertBar'] > JSXAttribute[name.name='severity'] > Literal[value!=/^(?:critical|warning|info)$/]",
        "message": "<AlertBar> severity must be one of 'critical' | 'warning' | 'info'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ConfirmDialog'] > JSXAttribute > JSXIdentifier[name!=/^(?:open|title|destructive|message|impact|willRemove|willKeep|rollback|confirmPhrase|confirmLabel|onConfirm|onClose|key|ref|className|style|children)$/]",
        "message": "<ConfirmDialog> doesn't accept that prop. Declared props: open, title, destructive, message, impact, willRemove, willKeep, rollback, confirmPhrase, confirmLabel, onConfirm, onClose."
      },
      {
        "selector": "JSXOpeningElement[name.name='DiagnosticRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:key|value|status|key|ref|className|style|children)$/]",
        "message": "<DiagnosticRow> doesn't accept that prop. Declared props: key, value, status."
      },
      {
        "selector": "JSXOpeningElement[name.name='DriftDiff'] > JSXAttribute > JSXIdentifier[name!=/^(?:desired|actual|drift|key|ref|className|style|children)$/]",
        "message": "<DriftDiff> doesn't accept that prop. Declared props: desired, actual, drift."
      },
      {
        "selector": "JSXOpeningElement[name.name='TimelineEvent'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|time|target|message|result|level|family|actor|action|reason|key|ref|className|style|children)$/]",
        "message": "<TimelineEvent> doesn't accept that prop. Declared props: id, time, target, message, result, level, family, actor, action, reason."
      },
      {
        "selector": "JSXOpeningElement[name.name='HealthService'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|status|label|key|ref|className|style|children)$/]",
        "message": "<HealthService> doesn't accept that prop. Declared props: name, status, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='MetricStat'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|total|family|hint|icon|key|ref|className|style|children)$/]",
        "message": "<MetricStat> doesn't accept that prop. Declared props: label, value, total, family, hint, icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='NodeStreamSummary'] > JSXAttribute > JSXIdentifier[name!=/^(?:sensor|status|mp|port|rtpAge|key|ref|className|style|children)$/]",
        "message": "<NodeStreamSummary> doesn't accept that prop. Declared props: sensor, status, mp, port, rtpAge."
      },
      {
        "selector": "JSXOpeningElement[name.name='OperationStep'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|state|key|ref|className|style|children)$/]",
        "message": "<OperationStep> doesn't accept that prop. Declared props: label, state."
      },
      {
        "selector": "JSXOpeningElement[name.name='OperationStep'] > JSXAttribute[name.name='state'] > Literal[value!=/^(?:pending|active|ok|failed)$/]",
        "message": "<OperationStep> state must be one of 'pending' | 'active' | 'ok' | 'failed'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:state|label|family|size|dot|pulse|key|ref|className|style|children)$/]",
        "message": "<StatusBadge> doesn't accept that prop. Declared props: state, label, family, size, dot, pulse."
      },
      {
        "selector": "JSXOpeningElement[name.name='StreamRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:binding|node|sensor|status|rtpAgeMs|mountpoint|rtpPort|fdir|lastError|selected|onOpen|onRestart|onStop|onDiagnose|key|ref|className|style|children)$/]",
        "message": "<StreamRow> doesn't accept that prop. Declared props: binding, node, sensor, status, rtpAgeMs, mountpoint, rtpPort, fdir, lastError, selected, onOpen, onRestart, onStop, onDiagnose."
      },
      {
        "selector": "JSXOpeningElement[name.name='StreamRow'] > JSXAttribute[name.name='fdir'] > Literal[value!=/^(?:enabled|disabled|suppressed)$/]",
        "message": "<StreamRow> fdir must be one of 'enabled' | 'disabled' | 'suppressed'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ViewerTile'] > JSXAttribute > JSXIdentifier[name!=/^(?:binding|status|rtpAge|fdirEvent|pinned|media|onRestart|onDiagnose|onPin|onFullscreen|key|ref|className|style|children)$/]",
        "message": "<ViewerTile> doesn't accept that prop. Declared props: binding, status, rtpAge, fdirEvent, pinned, media, onRestart, onDiagnose, onPin, onFullscreen."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
